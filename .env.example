# =============================================================================
# GAIA OS — Environment Configuration Example
# Copy to .env and edit. Never commit .env to version control.
# =============================================================================

# Network
GAIA_HOST=0.0.0.0
GAIA_PORT=8000

# GAIA data root (GAIAN homes, memory, manifests)
# Mount a persistent volume here in production.
GAIA_ROOT=/data/gaia

# Auth
# Comma-separated list of Bearer tokens. Each token value IS the caller_id.
# Empty = auth disabled (development only).
# Example: GAIA_BEARER_TOKENS=ui-prod-token,mobile-token,gaian-abc123
GAIA_BEARER_TOKENS=

# CORS
# Comma-separated list of allowed origins.
# Use specific origins in production instead of *.
GAIA_CORS_ORIGINS=*

# Reload (development only — never use in production)
GAIA_RELOAD=false

# Worker processes
# Keep at 1 until shared registry/memory persistence is implemented.
# Multiple workers will each have their own in-process session.
GAIA_WORKERS=1

# Boot sequence tracking
GAIA_BOOT_NUMBER=1
