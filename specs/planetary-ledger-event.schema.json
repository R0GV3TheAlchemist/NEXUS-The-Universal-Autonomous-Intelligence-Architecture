{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.gaian/schemas/planetary-ledger-event.schema.json",
  "title": "PlanetaryLedgerEvent",
  "description": "Schema for an immutable event entry on the NEXUS planetary ledger. Supports provenance tracking, sovereign memory anchoring, and audit trails.",
  "type": "object",
  "required": ["event_id", "event_type", "source_node", "timestamp", "payload", "signature"],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique UUID4 for this ledger event."
    },
    "event_type": {
      "type": "string",
      "enum": [
        "capability_granted",
        "capability_revoked",
        "policy_violation",
        "module_restart",
        "twin_sync",
        "memory_commit",
        "session_init",
        "session_close",
        "schumann_sync",
        "crisis_triggered",
        "governance_audit",
        "custom"
      ],
      "description": "Canonical event type for ledger classification."
    },
    "source_node": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the NEXUS node that originated this event."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO 8601 timestamp when the event was recorded."
    },
    "payload": {
      "type": "object",
      "description": "Event-specific structured data payload.",
      "additionalProperties": true
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "value"],
      "additionalProperties": false,
      "description": "Cryptographic signature for event integrity.",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["Ed25519", "ECDSA-P256", "HMAC-SHA256"],
          "description": "Signature algorithm used."
        },
        "value": {
          "type": "string",
          "description": "Base64-encoded signature value."
        },
        "key_id": {
          "type": "string",
          "description": "Optional key identifier for signature verification."
        }
      }
    },
    "parent_event_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the parent event for causal chaining (Merkle-DAG provenance)."
    },
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the GAIA session this event belongs to."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semver) for forward compatibility."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags for filtering and routing."
    }
  }
}
