{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nexus.gaian/schemas/nexus-universal-os.schema.json",
  "title": "NEXUSUniversalOS",
  "description": "Root schema for a NEXUS Universal OS node configuration and identity manifest.",
  "type": "object",
  "required": ["node_id", "version", "profile", "capabilities", "governance"],
  "additionalProperties": false,
  "properties": {
    "node_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique UUID4 identifier for this NEXUS node."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this node manifest (e.g., '1.0.0')."
    },
    "profile": {
      "type": "object",
      "required": ["name", "tier", "sovereign_identity"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of this NEXUS node (e.g., 'GAIA-Node-Alpha')."
        },
        "tier": {
          "type": "string",
          "enum": ["personal", "community", "planetary", "interplanetary"],
          "description": "Operating tier for this node."
        },
        "sovereign_identity": {
          "type": "string",
          "description": "GAIAN sovereign identity string (DID or node-specific URI)."
        },
        "description": {
          "type": "string",
          "description": "Optional description of this node's purpose."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC ISO 8601 creation timestamp."
        }
      }
    },
    "capabilities": {
      "type": "array",
      "description": "List of capability tokens granted to this node.",
      "items": {
        "$ref": "capability-token.schema.json"
      }
    },
    "modules": {
      "type": "object",
      "description": "Active module configuration per module name.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "version": { "type": "string" },
          "config": { "type": "object" }
        }
      }
    },
    "governance": {
      "type": "object",
      "required": ["policy_refs", "risk_level"],
      "additionalProperties": false,
      "properties": {
        "policy_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to active governance policy IDs (UUIDs)."
        },
        "risk_level": {
          "type": "string",
          "enum": ["minimal", "limited", "high", "unacceptable"],
          "description": "EU AI Act risk classification for this node."
        },
        "compliance_frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Declared compliance frameworks (e.g., 'EU AI Act', 'NIST AI RMF', 'IEEE EAD')."
        }
      }
    },
    "schumann_sync": {
      "type": "object",
      "description": "Schumann resonance synchronisation state.",
      "properties": {
        "confirmed": { "type": "boolean" },
        "frequency_hz": { "type": "number" },
        "last_sync": { "type": "string", "format": "date-time" }
      }
    },
    "meta": {
      "type": "object",
      "description": "Arbitrary metadata for extensibility.",
      "additionalProperties": true
    }
  }
}
