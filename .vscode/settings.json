{
  // ─────────────────────────────────────────────────────────────────────────
  // GAIA-OS — VS Code / Cursor workspace settings
  // Commit this file so every contributor gets the same editor behaviour.
  // Works identically in Cursor (which reads .vscode/settings.json natively).
  //
  // Canon Ref: C30 (No silent failures) — lint fires on every save,
  // not just in CI. A red squiggle is better than a failed PR.
  // ─────────────────────────────────────────────────────────────────────────

  // ── Python: Ruff as the single formatter + linter ─────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      // Apply all safe Ruff fixes on save (same as --fix in CI)
      "source.fixAll.ruff": "explicit",
      // Organise and sort imports on save (enforces I001 locally)
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ── Ruff extension settings ───────────────────────────────────────────────
  "ruff.enable": true,
  "ruff.fixAll": true,
  "ruff.organizeImports": true,
  // Use the project-local ruff (from .venv) rather than a global install.
  // Ensures the editor uses the exact same version as CI.
  "ruff.interpreter": ["${workspaceFolder}/.venv/bin/python"],

  // ── Type checking: mypy ───────────────────────────────────────────────────
  "python.analysis.typeCheckingMode": "basic",
  "mypy-type-checker.enabled": true,
  "mypy-type-checker.args": [
    "--ignore-missing-imports",
    "--follow-imports=silent"
  ],

  // ── Python interpreter ────────────────────────────────────────────────────
  // Auto-selects the project venv if present.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,

  // ── Editor: general quality-of-life ──────────────────────────────────────
  "editor.rulers": [100],             // matches ruff line-length = 100
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ── File associations ─────────────────────────────────────────────────────
  "files.associations": {
    "*.md": "markdown",
    "*.env.example": "dotenv",
    "GAIAmanifest.json": "json",
    "*.spec": "python"              // gaia-backend.spec is a PyInstaller spec
  },

  // ── Search / explorer: exclude noise ─────────────────────────────────────
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/__pycache__": true,
    "**/*.egg-info": true,
    "**/pnpm-lock.yaml": true,
    "**/package-lock.json": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.egg-info": true
  },

  // ── Terminal ──────────────────────────────────────────────────────────────
  "terminal.integrated.env.osx": {
    "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/core:${workspaceFolder}/src-python"
  },
  "terminal.integrated.env.linux": {
    "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/core:${workspaceFolder}/src-python"
  },
  "terminal.integrated.env.windows": {
    "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/core;${workspaceFolder}/src-python"
  },

  // ── Extensions: recommended installs (shown as suggestions to new devs) ───
  // See .vscode/extensions.json for the full list.

  // ── Markdown: canon docs rendering ───────────────────────────────────────
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    }
  },

  // ── YAML ─────────────────────────────────────────────────────────────────
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.formatOnSave": true
  },

  // ── JSON ─────────────────────────────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },

  // ── TypeScript / JS (gaia-tt, Tauri frontend) ─────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  }
}
