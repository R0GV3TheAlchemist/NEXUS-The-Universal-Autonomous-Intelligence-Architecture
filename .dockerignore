# =============================================================================
# .dockerignore — keep the GAIA image lean
# =============================================================================

# Version control
.git/
.gitignore

# Python byte-code and caches
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Virtual environments
.venv/
venv/
env/

# Test outputs and coverage
htmlcov/
.coverage
coverage.xml
*.log

# Local development data
# (The real data lives in the Docker volume at /data/gaia,
#  not in the source tree)
~/.gaia/
data/

# IDE and OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Docs build artefacts
docs/_build/
site/

# Docker files themselves (no infinite recursion)
Dockerfile*
docker-compose*.yml
