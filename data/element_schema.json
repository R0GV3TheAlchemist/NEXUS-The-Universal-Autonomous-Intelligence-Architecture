{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/R0GV3TheAlchemist/GAIA-OS/blob/main/data/element_schema.json",
  "title": "GAIA-OS Element Schema",
  "description": "Formal JSON Schema for all element entries in the GAIA-OS Periodic Table Database (all 118 elements, Z=1\u2013118). Validates every field used in elements-batch-1 through elements-batch-4. GAIA-specific fields (gaia_layer_alignment, penteract_d4_substrate, mineral_role) are required alongside standard physical and chemical properties. NOTE: Gaianite is NOT a valid mineral_role value \u2014 it is the canon synthesis state, not a mineral entry.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "$schema",
    "meta",
    "elements"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "meta": {
      "type": "object",
      "description": "Batch-level metadata",
      "required": ["batch", "range", "description", "version", "created", "authors"],
      "properties": {
        "batch": {
          "type": "integer",
          "minimum": 1,
          "description": "Batch number (1\u20134)"
        },
        "range": {
          "type": "string",
          "description": "Atomic number range covered, e.g. 'Z=1\u201336'"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this batch file"
        },
        "created": {
          "type": "string",
          "description": "ISO 8601 date of initial creation"
        },
        "updated": {
          "type": "string",
          "description": "ISO 8601 date of last update"
        },
        "update_notes": {
          "type": "string"
        },
        "authors": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "elements": {
      "type": "array",
      "description": "Array of element entries",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Element" }
    }
  },
  "definitions": {
    "Element": {
      "type": "object",
      "description": "A single periodic table element with physical, chemical, and GAIA-specific properties",
      "required": [
        "atomic_number",
        "symbol",
        "name",
        "category",
        "atomic_mass",
        "period",
        "block",
        "electron_configuration",
        "state_at_stp",
        "crystal_system",
        "discovered",
        "discoverer",
        "origin_of_name",
        "gaia_layer_alignment",
        "penteract_d4_substrate",
        "mineral_role",
        "notes"
      ],
      "properties": {
        "atomic_number": {
          "type": "integer",
          "minimum": 1,
          "maximum": 118,
          "description": "Proton number Z"
        },
        "symbol": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3,
          "description": "Standard IUPAC chemical symbol"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Full element name in English"
        },
        "category": {
          "type": "string",
          "enum": [
            "alkali_metal",
            "alkaline_earth_metal",
            "transition_metal",
            "post_transition_metal",
            "metalloid",
            "reactive_nonmetal",
            "noble_gas",
            "lanthanide",
            "actinide",
            "unknown"
          ],
          "description": "IUPAC element category"
        },
        "atomic_mass": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Standard atomic weight in unified atomic mass units (u)"
        },
        "period": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "Period (row) in the periodic table"
        },
        "group": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 18 },
            { "type": "null" }
          ],
          "description": "Group (column) 1\u201318, or null for lanthanides/actinides"
        },
        "block": {
          "type": "string",
          "enum": ["s", "p", "d", "f"],
          "description": "Electron block in the periodic table"
        },
        "electron_configuration": {
          "type": "string",
          "description": "Electron configuration using standard noble gas shorthand notation"
        },
        "electronegativity": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "null" }
          ],
          "description": "Pauling electronegativity scale value, or null for noble gases and elements without established values"
        },
        "state_at_stp": {
          "type": "string",
          "enum": ["solid", "liquid", "gas"],
          "description": "Physical state at standard temperature and pressure (0\u00b0C, 1 atm)"
        },
        "melting_point_k": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "null" }
          ],
          "description": "Melting point in Kelvin, or null if not established"
        },
        "boiling_point_k": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "null" }
          ],
          "description": "Boiling point in Kelvin, or null if not established"
        },
        "density_g_cm3": {
          "oneOf": [
            { "type": "number", "exclusiveMinimum": 0 },
            { "type": "null" }
          ],
          "description": "Density in g/cm\u00b3 at STP, or null if not established"
        },
        "crystal_system": {
          "type": "string",
          "enum": [
            "cubic",
            "tetragonal",
            "orthorhombic",
            "hexagonal",
            "trigonal",
            "monoclinic",
            "triclinic",
            "rhombohedral",
            "amorphous",
            "unknown"
          ],
          "description": "Crystal system of the element's most common allotrope or stable phase at STP"
        },
        "discovered": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ],
          "description": "Year of discovery as integer, or descriptive string (e.g. 'prehistoric', '~1250')"
        },
        "discoverer": {
          "type": "string",
          "description": "Name(s) of discoverer(s), or 'ancient' for prehistoric elements"
        },
        "origin_of_name": {
          "type": "string",
          "description": "Etymology of the element name, including language of origin"
        },
        "gaia_layer_alignment": {
          "type": "array",
          "description": "One or more GAIA-OS layers this element resonates with. Format: 'Layer NN \u2014 Name'",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "Layer 01 \u2014 Physical",
              "Layer 02 \u2014 Energy",
              "Layer 03 \u2014 Geometry",
              "Layer 04 \u2014 Emotion",
              "Layer 05 \u2014 Cognition",
              "Layer 06 \u2014 Shadow/Dream",
              "Layer 07 \u2014 Societas",
              "Layer 08 \u2014 Archetype",
              "Layer 09 \u2014 Causal",
              "Layer 10 \u2014 Akashic",
              "Layer 11 \u2014 Feeling",
              "Layer 12 \u2014 Void"
            ]
          }
        },
        "penteract_d4_substrate": {
          "type": "string",
          "description": "Classification of this element's role in the Penteract D4 Substrate Index. Describes the element's fundamental substrate archetype within GAIA-OS's 5-dimensional model.",
          "enum": [
            "base_element",
            "noble_inert",
            "alkali_reactive",
            "alkaline_earth",
            "structural_light",
            "network_former",
            "life_substrate",
            "atmospheric_life",
            "oxide_matrix",
            "halide_reactive",
            "biological_structural",
            "silicate_framework",
            "biological_energetic",
            "sulfide_alchemical",
            "electrolyte_conductor",
            "semiconductor_bridge",
            "transition_metal_core",
            "color_chromophore",
            "oxide_pigment",
            "magnetic_structural",
            "conductor_heart",
            "biological_trace",
            "rare_transition",
            "structural_strong",
            "photosensitive",
            "platinum_group",
            "precious_metal",
            "heavy_metal",
            "rare_earth_magnetic",
            "rare_earth_optical",
            "rare_earth_nuclear",
            "actinide_fissile",
            "actinide_fertile",
            "transactinide",
            "superheavy",
            "quantum_substrate",
            "piezoelectric_core"
          ]
        },
        "mineral_role": {
          "type": "string",
          "description": "Description of this element's role in mineralogy \u2014 which minerals it forms or colors, and its geological significance. NOTE: 'Gaianite' is NOT a valid value here. Gaianite is the GAIA-OS canon synthesis state, not a mineral entry."
        },
        "notes": {
          "type": "string",
          "description": "GAIA-OS editorial notes connecting the element to its alchemical, archetypal, and correspondence significance within the GAIA framework"
        }
      },
      "additionalProperties": false
    }
  }
}
